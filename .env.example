# --- On-chain (Vite client; must be prefixed with VITE_) ---
# Defaults are committed in `.env`. Copy this file to `.env.local` to override locally (gitignored).
# On Vercel: set the same `VITE_*` names under Project → Settings → Environment Variables (optional; repo `.env` is used if unset).
VITE_TOKEN_FETH_ADDRESS=0x8D9263E921df92354e5D2dA8F064726887e70756
VITE_TOKEN_FT564_ADDRESS=0xB977127AbD2BCc57782749B63EbBB69Ec7bDA1f7
VITE_PAIR_V2_ADDRESS=0xaBAd60866a67bd7A4f6e906da20964E6c9b5FC8D
# Uniswap V2 Router02 on Sepolia (official factory). Pair must be created by that factory.
VITE_UNISWAP_V2_ROUTER_ADDRESS=0xeE567Fe1712Faf6149d80dA1E6934E354124CfE3

# Fact Finance trade API — default same-origin `/api/fact/*` (Vite dev proxy + Vercel rewrite → api.fact.finance).
# Override base only if you need a different origin (and CORS allows), e.g.:
# VITE_FACT_TRADE_API_BASE=https://api.fact.finance
# Per-endpoint overrides (optional):
# VITE_POOL_PRICE_URL=/pool-price.json
# VITE_LEADERBOARD_STANDINGS_URL=/leaderboard-standings.json
# VITE_LEADERBOARD_RANK_URL=/rank-evolution.json

# Optional — scripts/fetch-pool-price.ts (npm run fetch-pool-price)
# SEPOLIA_RPC_URL=https://...
# POOL_PRICE_JSON=./public/pool-price.json

# Required for scripts/fetch-holder-balances.ts (npm run fetch-holder-balances) — Sepolia Etherscan API key
# VITE_ETHERSCAN_API_KEY=YourEtherscanApiKey
# HOLDERS_CSV=./data/holders.csv
# HOLDERS_BALANCE_CSV=./data/holder-balances.csv
# HOLDERS_EVOLUTION_CSV=./data/rank-evolution.csv
# HOLDERS_PUBLIC_STANDINGS_JSON=./public/leaderboard-standings.json
# HOLDERS_PUBLIC_EVOLUTION_JSON=./public/rank-evolution.json
# HOLDERS_ETHERSCAN_DELAY_MS=450

